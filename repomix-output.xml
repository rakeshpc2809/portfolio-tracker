  const hasRealScores = fund.yieldScore > 0 || fund.riskScore > 0 || fund.valueScore > 0;
  
  const components = [
    { 
      label: 'Yield', 
      score: hasRealScores ? fund.yieldScore : (fund.convictionScore || 0) * 0.8, 
