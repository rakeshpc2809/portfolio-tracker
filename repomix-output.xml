<file path="docker-compose.yml">
# Create a .env file to override these defaults in production
# .env should contain:
# DB_PASSWORD=your_secure_password
# GOOGLE_SHEET_URL=your_csv_url
# PORTFOLIO_API_KEY=your_secure_api_key

services:
  postgres:
    image: postgres:16-alpine
    container_name: cas_postgres
    environment:
      POSTGRES_USER: ${DB_USER:-user}
      POSTGRES_PASSWORD: ${DB_PASSWORD:-password}
      POSTGRES_DB: ${DB_NAME:-cas_db}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    restart: always
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER:-user} -d ${DB_NAME:-cas_db}"]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 15s

  # 2. The Java Backend
  java-backend:
    build:
      context: .
      dockerfile: cas-injector/Dockerfile
    container_name: cas_java_app
    ports:
      - "8080:8080"
    environment:
      - SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/${DB_NAME:-cas_db}
      - SPRING_DATASOURCE_USERNAME=${DB_USER:-user}
      - SPRING_DATASOURCE_PASSWORD=${DB_PASSWORD:-password}
      - GOOGLE_SHEET_URL=${GOOGLE_SHEET_URL:-https://docs.google.com/spreadsheets/d/e/2PACX-1vTq7bqtww_gsZv4FPXBWErHOSmuPSNrnL-82cno8rShNP9TsTOjJmkPBnocg_GqSWALUQo9YEI_dyto/pub?gid=412111003&single=true&output=csv}
      - PORTFOLIO_API_KEY=${PORTFOLIO_API_KEY:-dev-secret-key}
    volumes:
      - ./logs:/app/logs
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/api/admin/status"]
      interval: 10s
      timeout: 5s
      retries: 8
      start_period: 30s

  # 3. The Python Parser
  python-parser:
    build: ./cas-parser
    container_name: cas_python_app
    ports:
      - "8000:8000"
    environment:
      - JAVA_BACKEND_URL=http://java-backend:8080/api/cas/inject
      - PORTFOLIO_API_KEY=${PORTFOLIO_API_KEY:-dev-secret-key}
    depends_on:
      java-backend:
        condition: service_healthy

  # 4. The React Frontend
  react-frontend:
    build: ./portfolio-dashboard
    container_name: cas_react_ui
    ports:
      - "80:80"
    depends_on:
      java-backend:
        condition: service_healthy
    restart: always

volumes:
  postgres_data:
</file>

<file path="cas-injector/src/main/java/com/oreki/cas_injector/core/dto/SchemePerformanceDTO.java">
package com.oreki.cas_injector.core.dto;

import java.math.BigDecimal;
import java.time.LocalDate;
import java.util.List;

import com.oreki.cas_injector.core.utils.FundStatus;

import lombok.AllArgsConstructor;
import lombok.Builder;
import lombok.Data;
import lombok.NoArgsConstructor;
@Data
@Builder
@AllArgsConstructor
@NoArgsConstructor // Added for better compatibility with some JSON mappers
public class SchemePerformanceDTO {
    private String schemeName;
    private String isin;
    private String amfiCode;
    
    // 1. Total Invested (Gross historical Buy amounts)
    private BigDecimal totalInvested; 
    
    // 2. Sold Amount (The "Cost Basis" portion of units you've exited)
    private BigDecimal soldAmountCost; 
    
    // 3. Current Invested (Total Invested - Sold Amount Cost)
    private BigDecimal currentInvested; 

    // 4. Current Value (Units Held * Current NAV)
    private BigDecimal currentValue;

    // 5. Realized Gain (Profit/Loss already "booked" in the bank)
    private BigDecimal realizedGain;

    private BigDecimal unrealizedGain;

    private long transactionCount;

