              <div className={`text-2xl font-medium tabular-nums mb-4 ${signal.action === 'BUY' ? 'text-buy' : 'text-exit'}`}>
                <CurrencyValue 
                  isPrivate={isPrivate} 
                  value={signal.action === 'BUY' 
