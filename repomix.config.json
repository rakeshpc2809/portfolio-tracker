{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "removeComments": true,
    "removeEmptyLines": true,
    "showLineNumbers": true,
    "topFilesLength": 10
  },
  "include": ["**/*"],
  "ignore": {
    "customPatterns": [
      "**/node_modules/**",
      "**/target/**",
      "**/dist/**",
      "**/build/**",
      "**/postgres_data/**",
      "**/logs/**",
      "**/.git/**",
      "**/.vscode/**",
      "**/*.odt",
      "**/*.xml",
      "temp.json",
      "repomix-output.xml",
      "portfolio_os_execution_plan.md",
      "allocation_plan.odt",
      "package-lock.json",
      "mvnw",
      "mvnw.cmd"
    ],
    "useGitignore": true,
    "useDefaultPatterns": true
  }
}
